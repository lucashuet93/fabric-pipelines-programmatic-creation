# Copy to .env and fill in real values. Loaded automatically by src/agent.py.

# --- Azure AI Foundry ---
FOUNDRY_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com
FOUNDRY_MODEL=gpt-4o

# --- Microsoft Fabric ---
# Workspace the generated pipelines target. Used when the agent needs to fill
# in workspaceId fields inside pipeline-content.json.
FABRIC_WORKSPACE_ID=00000000-0000-0000-0000-000000000000

# --- Azure DevOps (used for PR creation) ---
AZDO_ORG_URL=https://dev.azure.com/your-org
AZDO_PROJECT=your-project
AZDO_REPO=your-repo
AZDO_DEFAULT_BRANCH=main
# Personal access token. Required scopes: Code (read & write), Pull Request (read & write).
AZDO_PAT=
